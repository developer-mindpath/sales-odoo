<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Appears under Action menu on campaign list & form (reliable even if list header buttons are not obvious). -->
    <record id="action_email_camp_campaign_send_server" model="ir.actions.server">
        <field name="name">Send campaign</field>
        <field name="model_id" ref="model_email_camp_campaign"/>
        <field name="binding_model_id" ref="model_email_camp_campaign"/>
        <field name="binding_view_types">list,form</field>
        <field name="groups_id" eval="[(4, ref('email_camp.group_email_camp_user'))]"/>
        <field name="state">code</field>
        <field name="code">action = records.action_run_campaign()</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_email_camp_sync_inbox_replies_wizard_form" model="ir.ui.view">
        <field name="name">email_camp.sync.inbox.replies.wizard.form</field>
        <field name="model">email_camp.sync.inbox.replies.wizard</field>
        <field name="arch" type="xml">
            <form string="Sync inbox replies">
                <sheet>
                    <div class="oe_title">
                        <h1>Sync inbox replies</h1>
                    </div>
                    <div class="o_form_label">
                        Use this action to fetch unread replies from the configured IMAP inbox and create or update CRM leads from matched campaign responses.
                    </div>
                    <group string="Last result">
                        <field name="synced_count" readonly="1"/>
                        <field name="result_message" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run_sync" string="Run sync now" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_email_camp_sync_wizard" model="ir.actions.act_window">
        <field name="name">Sync inbox replies</field>
        <field name="res_model">email_camp.sync.inbox.replies.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>
</odoo>
